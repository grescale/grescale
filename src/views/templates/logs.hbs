<div class="p-6 lg:p-8">
  <div class="mb-6 flex items-start justify-between gap-4 border-b border-border pb-4">
    <div>
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">Activity</p>
      <h2 class="mt-2 text-2xl font-semibold tracking-tight text-foreground">System Logs</h2>
      <span class="mt-2 block text-sm text-muted-foreground">Recent API requests and errors</span>
    </div>
    <div>
      <span class="inline-flex rounded-md border border-border bg-muted px-2.5 py-1 text-xs font-medium text-foreground">{{count}} logs</span>
    </div>
  </div>

  {{#if logs}}
  <div class="overflow-hidden rounded-xl border border-border bg-card shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-border text-sm">
        <thead class="bg-muted/40 text-left font-medium text-muted-foreground">
          <tr>
            <th class="px-4 py-3 text-xs uppercase tracking-wider">Method</th>
            <th class="px-4 py-3 text-xs uppercase tracking-wider">Status</th>
            <th class="px-4 py-3 text-xs uppercase tracking-wider w-1/3">URL</th>
            <th class="px-4 py-3 text-xs uppercase tracking-wider">Collection</th>
            <th class="px-4 py-3 text-xs uppercase tracking-wider">IP / Agent</th>
            <th class="px-4 py-3 text-xs uppercase tracking-wider">Time</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {{#each logs}}
          <tr class="border-l-2 {{#if (gte this.status 400)}}border-red-400{{else}}border-emerald-400{{/if}} hover:bg-muted/30">
            <td class="px-4 py-4 whitespace-nowrap font-medium text-foreground">{{this.method}}</td>
            <td class="px-4 py-4 whitespace-nowrap">
              <span class="inline-flex rounded-md border px-2 py-1 text-xs font-medium {{#if (gte this.status 400)}}border-red-200 bg-red-50 text-red-700{{else}}border-emerald-200 bg-emerald-50 text-emerald-700{{/if}}">
                {{this.status}}
              </span>
            </td>
            <td class="px-4 py-4 break-all font-mono text-xs text-foreground">
              {{this.url}}
              {{#if this.error}}<div class="mt-1 break-words text-red-600">{{this.error}}</div>{{/if}}
            </td>
            <td class="px-4 py-4 whitespace-nowrap text-foreground">{{#if this.collection}}{{this.collection}}{{else}}<span class="italic text-muted-foreground">sys</span>{{/if}}</td>
            <td class="px-4 py-4 whitespace-nowrap text-xs text-muted-foreground">
              <div>{{this.user_ip}}</div>
              <div class="truncate max-w-[150px]" title="{{this.user_agent}}">{{this.user_agent}}</div>
            </td>
            <td class="px-4 py-4 whitespace-nowrap text-xs text-muted-foreground">{{this.created_at}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
  {{else}}
  <div class="rounded-xl border border-dashed border-border bg-card p-10 text-center text-muted-foreground">No logs found.</div>
  {{/if}}
</div>

