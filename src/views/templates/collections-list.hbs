{{#if tables}}
  {{#each tables}}
    <div data-collection-item data-collection-name="{{this.table_name}}" class="group flex items-center justify-between w-full rounded-lg border border-transparent bg-card px-3 py-2 transition-colors hover:border-border hover:bg-muted/50">
      <button 
        hx-get="{{../collectionsBase}}/{{this.table_name}}/records" 
        hx-target="#main-content"
        hx-push-url="/collections/{{this.table_name}}"
        class="flex flex-1 items-center justify-between rounded-md px-2 py-1.5 text-left text-sm font-medium text-foreground transition outline-none"
      >
        <span class="inline-flex items-center">
          {{#if (eq this.type "auth")}}
            <svg class="mr-2 inline-block h-4 w-4 align-middle text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 21a8 8 0 1 0-16 0"/><circle cx="12" cy="7" r="4"/></svg>
          {{else if (eq this.type "view")}}
            <svg class="mr-2 inline-block h-4 w-4 align-middle text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 3h8l4 4v14H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 3v4h4"/></svg>
          {{else}}
            <svg class="mr-2 inline-block h-4 w-4 align-middle text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/></svg>
          {{/if}}
          {{this.table_name}}
        </span>
      </button>
      <button hx-get="{{../collectionsBase}}/{{this.table_name}}/settings" hx-target="#drawer-container" class="rounded-md border border-transparent p-2 text-muted-foreground opacity-0 transition-colors hover:border-border hover:bg-muted hover:text-foreground group-hover:opacity-100" title="Settings">
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33h.02a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51h.02a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v.02a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </button>
    </div>
  {{/each}}
{{else}}
  <div class="rounded-lg border border-dashed border-border bg-card p-4 text-sm text-muted-foreground">No custom collections found.</div>
{{/if}}
