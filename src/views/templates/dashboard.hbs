<div class="p-6 lg:p-8 flex flex-col gap-6">
  <div class="max-w-2xl">
    <p
      class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground"
    >Overview</p>
    <h1
      class="mt-2 text-3xl font-semibold tracking-tight text-foreground"
    >Dashboard</h1>
    <p class="mt-2 text-sm text-muted-foreground">A quick look at the workspace.</p>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
    {{#each stats}}
      <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
        <h3
          class="text-sm font-medium text-muted-foreground"
        >{{this.label}}</h3>
        <p
          class="mt-3 text-2xl font-semibold tracking-tight text-foreground"
        >{{this.value}}</p>
      </div>
    {{/each}}
  </div>

  <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
    <h2
      class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground"
    >Quick Links</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      <a
        href="#"
        hx-get="{{baseUrl}}/collections"
        hx-target="#main-content"
        hx-push-url="/collections"
        class="rounded-md border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-muted"
      >Collections</a>
      <a
        href="#"
        hx-get="{{baseUrl}}/system-settings"
        hx-target="#main-content"
        hx-push-url="/settings"
        class="rounded-md border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-muted"
      >Settings</a>
      <a
        href="#"
        hx-get="{{baseUrl}}/logs"
        hx-target="#main-content"
        hx-push-url="/logs"
        class="rounded-md border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-muted"
      >Logs</a>
    </div>
  </div>
</div>